rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isTeacher() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // Assessment PDFs: teacher writes; matching parent or any teacher reads
    match /assessments/{studentId}/{rest=**} {
      allow write: if isTeacher();
      allow read:  if request.auth != null
        && (request.auth.uid == studentId || isTeacher());
    }
  }
}
