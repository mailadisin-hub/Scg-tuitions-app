rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed()  { return request.auth != null; }
    function uid()       { return request.auth.uid; }
    function userRole()  { return get(/databases/$(database)/documents/users/$(uid())).data.role; }
    function isTeacher() { return isAuthed() && userRole() == 'teacher'; }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isAuthed();
      allow write: if uid() == userId;
    }

    // ── Conversations (two-way chat) ─────────────────────────────────────────
    match /conversations/{convId} {
      allow read, update: if isAuthed()
        && (resource.data.teacherId == uid() || resource.data.parentId == uid());
      allow create: if isTeacher();

      match /messages/{msgId} {
        allow read: if isAuthed()
          && (get(/databases/$(database)/documents/conversations/$(convId)).data.teacherId == uid()
           || get(/databases/$(database)/documents/conversations/$(convId)).data.parentId  == uid());
        allow create: if isAuthed()
          && request.resource.data.senderId == uid();
        allow update: if false;
      }
    }

    // ── Attendance ───────────────────────────────────────────────────────────
    match /attendance/{docId} {
      allow create, update: if isTeacher();
      allow read:   if isAuthed()
        && (resource.data.studentId == uid() || resource.data.teacherId == uid());
      allow delete: if isTeacher() && resource.data.teacherId == uid();
    }

    // ── Homework ─────────────────────────────────────────────────────────────
    match /homework/{docId} {
      allow create, update: if isTeacher();
      allow read:   if isAuthed()
        && (resource.data.studentId == uid() || resource.data.teacherId == uid());
      allow delete: if isTeacher() && resource.data.teacherId == uid();
    }

    // ── Books ────────────────────────────────────────────────────────────────
    match /books/{docId} {
      allow create, update: if isTeacher();
      allow read:   if isAuthed()
        && (resource.data.studentId == uid() || resource.data.teacherId == uid());
      allow delete: if isTeacher() && resource.data.teacherId == uid();
    }

    // ── Payments ─────────────────────────────────────────────────────────────
    match /payments/{docId} {
      allow create:  if isTeacher();
      allow update:  if isTeacher() && resource.data.teacherId == uid();
      allow read:    if isAuthed()
        && (resource.data.parentId == uid() || resource.data.teacherId == uid());
      allow delete:  if false;
    }

    // ── Assessments ──────────────────────────────────────────────────────────
    match /assessments/{docId} {
      allow create:  if isTeacher();
      allow update:  if isTeacher() && resource.data.teacherId == uid();
      allow read:    if isAuthed()
        && (resource.data.studentId == uid() || resource.data.teacherId == uid());
      allow delete:  if isTeacher() && resource.data.teacherId == uid();
    }

    // ── Registrations ────────────────────────────────────────────────────────
    match /registrations/{docId} {
      allow create, update: if isAuthed()
        && (uid() == resource.data.parentId || isTeacher());
      allow create: if isAuthed();   // first write (no resource yet)
      allow read:   if isAuthed()
        && (resource.data.parentId == uid() || isTeacher());
    }

    // ── Settings (global config, written by teacher/admin) ───────────────────
    match /settings/{docId} {
      allow read:  if isAuthed();
      allow write: if isTeacher();
    }
  }
}
